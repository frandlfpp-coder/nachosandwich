/**
 * Core Philosophy: This ruleset enforces a strict user-ownership security model. All application data
 * is segregated into private data silos, where each user can only access and manage their own information.
 * There is no public or shared data in this model.
 *
 * Data Structure: The entire data hierarchy is nested under a path that includes the user's unique
 * Firebase Authentication UID: `/artifacts/{appId}/users/{userId}/...`. This structure makes it
 * impossible for one user to even reference another user's data tree.
 *
 * Key Security Decisions:
 * - Strict Ownership: All data, including products, orders, and transactions, is owned by a single user.
 *   There are no collaborative features or shared documents.
 * - No Public Listing: Users cannot list other user profiles or any data outside of their own
 *   sandboxed environment.
 * - Authorization Independence: Every user-owned document contains a denormalized `userId` field.
 *   This, combined with the `userId` in the path, allows for simple, fast, and secure rule logic
 *   that does not require expensive `get()` calls to other documents for authorization checks.
 * - Path and Data Consistency: Rules enforce that the `userId` within a document's data must always
 *   match the `userId` in its path, ensuring relational integrity is maintained from the moment of creation.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------

    /**
     * Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user's UID matches the given userId.
     * This is the foundation of the ownership model.
     * @param userId The UID to check against the authenticated user.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Verifies ownership for an existing document. Used for update and delete operations.
     * @param userId The UID of the document owner.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * Validates that the 'id' field of a new UserProfile matches the user's auth UID.
     * Enforces consistency between the document's ID and its internal data.
     */
    function isCreatingOwnProfile(userId) {
      return isOwner(userId) && request.resource.data.id == request.auth.uid;
    }



    /**
     * Validates that the 'userId' field in a new subcollection document matches the owner's auth UID.
     * This ensures every new document is correctly linked to its owner.
     */
    function isCreatingOwnSubcollectionDoc(userId) {
        return isOwner(userId) && request.resource.data.userId == request.auth.uid;
    }

    /**
      * Ensures that the 'userId' field on an existing subcollection document cannot be changed.
      * This prevents re-assigning ownership of a document.
      */
    function isUserIdImmutable() {
        return request.resource.data.userId == resource.data.userId;
    }
    
    // --------------------------------
    // Collection Rules
    // --------------------------------

    match /artifacts/{appId} {

      /**
       * @description Controls access to a user's own profile document.
       * @path /artifacts/{appId}/users/{userId}
       * @allow (create) An authenticated user creating their own profile document for the first time.
       * @deny (get) An authenticated user trying to read another user's profile.
       * @principle Restricts access to a user's own data tree and allows self-creation of a root profile.
       */
      match /users/{userId} {
        allow get: if isOwner(userId);
        allow list: if false; // A user should never need to list their own single profile document.
        allow create: if isCreatingOwnProfile(userId);
        allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
        allow delete: if isExistingOwner(userId);

        /**
         * @description Secures product documents owned by a user.
         * @path /artifacts/{appId}/users/{userId}/products/{productId}
         * @allow (create) An authenticated user adding a new product to their own product list.
         * @deny (update) A user trying to modify a product owned by another user.
         * @principle Enforces document ownership for all operations and validates relational integrity.
         */
        match /products/{productId} {
          allow get: if isOwner(userId);
          allow list: if isOwner(userId);
          allow create: if isCreatingOwnSubcollectionDoc(userId);
          allow update: if isExistingOwner(userId) && isUserIdImmutable();
          allow delete: if isExistingOwner(userId);
        }

        /**
         * @description Secures topping documents owned by a user.
         * @path /artifacts/{appId}/users/{userId}/toppings/{toppingId}
         * @allow (list) An authenticated user listing all toppings they own.
         * @deny (create) A user trying to create a topping under another user's profile.
         * @principle Enforces document ownership for all operations and validates relational integrity.
         */
        match /toppings/{toppingId} {
          allow get: if isOwner(userId);
          allow list: if isOwner(userId);
          allow create: if isCreatingOwnSubcollectionDoc(userId);
          allow update: if isExistingOwner(userId) && isUserIdImmutable();
          allow delete: if isExistingOwner(userId);
        }

        /**
         * @description Secures inventory stock items owned by a user.
         * @path /artifacts/{appId}/users/{userId}/stockItems/{stockItemId}
         * @allow (list) An authenticated user listing all stock items they own.
         * @deny (create) A user trying to create a stock item under another user's profile.
         * @principle Enforces document ownership for all operations and validates relational integrity.
         */
        match /stockItems/{stockItemId} {
          allow get: if isOwner(userId);
          allow list: if isOwner(userId);
          allow create: if isCreatingOwnSubcollectionDoc(userId);
          allow update: if isExistingOwner(userId) && isUserIdImmutable();
          allow delete: if isExistingOwner(userId);
        }

        /**
         * @description Secures customer orders owned by a user.
         * @path /artifacts/{appId}/users/{userId}/orders/{orderId}
         * @allow (get) An authenticated user reading the details of one of their own orders.
         * @deny (delete) A user trying to delete an order that belongs to someone else.
         * @principle Enforces document ownership for all operations and validates relational integrity.
         */
        match /orders/{orderId} {
          allow get: if isOwner(userId);
          allow list: if isOwner(userId);
          allow create: if isCreatingOwnSubcollectionDoc(userId);
          allow update: if isExistingOwner(userId) && isUserIdImmutable();
          allow delete: if isExistingOwner(userId);
        }

        /**
         * @description Secures financial transaction records owned by a user.
         * @path /artifacts/{appId}/users/{userId}/transactions/{transactionId}
         * @allow (create) An authenticated user recording a new transaction for their business.
         * @deny (list) A user attempting to list financial transactions belonging to another user.
         * @principle Enforces document ownership for all operations and validates relational integrity.
         */
        match /transactions/{transactionId} {
          allow get: if isOwner(userId);
          allow list: if isOwner(userId);
          allow create: if isCreatingOwnSubcollectionDoc(userId);
          allow update: if isExistingOwner(userId) && isUserIdImmutable();
          allow delete: if isExistingOwner(userId);
        }

        /**
         * @description Secures end-of-day financial closure reports owned by a user.
         * @path /artifacts/{appId}/users/{userId}/closures/{closureId}
         * @allow (get) An authenticated user retrieving a historical closure report they created.
         * @deny (update) A user trying to alter a closure report owned by another business.
         * @principle Enforces document ownership for all operations and validates relational integrity.
         */
        match /closures/{closureId} {
          allow get: if isOwner(userId);
          allow list: if isOwner(userId);
          allow create: if isCreatingOwnSubcollectionDoc(userId);
          allow update: if isExistingOwner(userId) && isUserIdImmutable();
          allow delete: if isExistingOwner(userId);
        }
      }
    }
  }
}
